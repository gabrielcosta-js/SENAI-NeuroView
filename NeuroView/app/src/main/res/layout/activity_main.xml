<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Preview da camera (ocupa a tela inteira) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Overlay transparente que desenha os bounding boxes por cima da camera -->
    <com.example.neuroview.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Barra de status no topo (mostra se o modelo carregou) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#BB000000"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvModelStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicializando..."
            android:textColor="#FFFF00"
            android:textSize="13sp"
            android:fontFamily="monospace"/>

    </LinearLayout>

    <!-- Barra de deteccao na parte inferior (mostra o objeto detectado) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#BB000000"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvDetectedObject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aguardando deteccao..."
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:gravity="center"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#00FF88"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

</FrameLayout>
